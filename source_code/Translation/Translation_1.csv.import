[remap]

importer="csv_translation"
type="Translation"

[deps]

files=[ "res://Translation/Translation_1.en_US.translation", "res://Translation/Translation_1.pt_BR.translation", "res://Translation/Translation_1.fr.translation" ]

source_file="res://Translation/Translation_1.csv"
dest_files=[ "res://Translation/Translation_1.en_US.translation", "res://Translation/Translation_1.pt_BR.translation", "res://Translation/Translation_1.fr.translation" ]

[params]

compress=true
delimiter=0
