[application]

config/name="Dystopia App stable==GodotAdmob+GodotAppodeal"
config/description="Changing the World? Sigh. A very lofty dream. It is a feat few men ever really achieve.It's an idea that infectts men to hope, fight, kill and to die. It was for this dream we hoped, fought, killed, starved, bled and died for in a hellish war that lasted 5 years. After fighting for so long, you lose sight if what you're really fighting for; and when you lose someone you love, all those lofty dreams you so valiantly fought for suddenly lose meaning. After all, what is the point of changing the world, when you have no one left to share it with.

A Stable build for the Dystopia App, preloaded with Chapters 1-3. Read the Comics, Watch the Anime, Play the Game, all in one app. It's a playable comic."
run/main_scene="res://scenes/UI & misc/form/form.tscn"
run/flush_stdout_on_print=true
run/flush_stdout_on_print.debug=false
boot_splash/image="res://resources/title animation/Dystopia Logo Drop shadow.png"
boot_splash/fullsize=false
boot_splash/use_filter=false
boot_splash/bg_color=Color( 1, 1, 1, 1 )
config/icon="res://icon.png"
config/windows_native_icon="res://windows icon.ico"

[autoload]

Dialogs="*res://singletons/Dialogs.gd"
Debug="*res://singletons/Debug.gd"
Quest="*res://singletons/Quest.gd"
Inventory="*res://singletons/Inventory.gd"
Globals="*res://singletons/Globals.gd"
Music="*res://singletons/Music.tscn"
Networking="*res://singletons/Networking.tscn"
Comics_v5="*res://singletons/Comics.v5.1.gd"
AsyncExecutorDriver="*res://addons/algodot/gdnative/async_executor.gdns"
GlobalAnimation="*res://singletons/GlobalAnimationPlayer.tscn"
Wallet="*res://scenes/Wallet/Wallet.gd"
DocsHelper="*res://addons/algodot/Documentation/Scripts/DocsHelper.gd"

[debug]

gdscript/completion/autocomplete_setters_and_getters=true

[display]

window/dpi/allow_hidpi=true
window/handheld/orientation="sensor"
window/stretch/mode="2d"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PoolStringArray( "res://addons/algodot/plugin.cfg" )

[gdnative]

singletons=[ "res://addons/videodecoder/videodecoder.gdnlib", "res://webrtc/webrtc.tres" ]
singletons_disabled=[  ]

[global]

keys=NodePath("")

